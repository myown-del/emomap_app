      "/api/emotions/me": {
        "get": {
          "tags": [
            "Emotions"
          ],
          "summary": "Get User Emotions",
          "operationId": "get_user_emotions_api_emotions_me_get",
          "parameters": [
            {
              "name": "min_rating",
              "in": "query",
              "required": false,
              "schema": {
                "anyOf": [
                  {
                    "type": "integer",
                    "maximum": 10,
                    "minimum": 1
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Filter emotions with rating greater than or equal to this value",
                "title": "Min Rating"
              },
              "description": "Filter emotions with rating greater than or equal to this value"
            },
            {
              "name": "max_rating",
              "in": "query",
              "required": false,
              "schema": {
                "anyOf": [
                  {
                    "type": "integer",
                    "maximum": 10,
                    "minimum": 1
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Filter emotions with rating less than or equal to this value",
                "title": "Max Rating"
              },
              "description": "Filter emotions with rating less than or equal to this value"
            },
            {
              "name": "date_from",
              "in": "query",
              "required": false,
              "schema": {
                "anyOf": [
                  {
                    "type": "string",
                    "format": "date"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Filter emotions created after this date (inclusive)",
                "title": "Date From"
              },
              "description": "Filter emotions created after this date (inclusive)"
            },
            {
              "name": "date_to",
              "in": "query",
              "required": false,
              "schema": {
                "anyOf": [
                  {
                    "type": "string",
                    "format": "date"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Filter emotions created before this date (inclusive)",
                "title": "Date To"
              },
              "description": "Filter emotions created before this date (inclusive)"
            },
            {
              "name": "session_id",
              "in": "cookie",
              "required": false,
              "schema": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Session Id"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Successful Response",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/EmotionResponse"
                    },
                    "title": "Response Get User Emotions Api Emotions Me Get"
