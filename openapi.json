      "/api/emotions/statistics/average/{period_type}": {
        "get": {
          "tags": [
            "Emotions"
          ],
          "summary": "Get Emotion Statistics",
          "description": "Get average rating of emotions for different time periods:\n\n- week: Average rating for each day of the last 7 days\n- month: Average rating for each week of the last month\n- year: Average rating for each month of the last year",
          "operationId": "get_emotion_statistics_api_emotions_statistics_average__period_type__get",
          "parameters": [
            {
              "name": "period_type",
              "in": "path",
              "required": true,
              "schema": {
                "$ref": "#/components/schemas/StatisticsPeriod",
                "description": "The time period to get statistics for: week, month, or year"
              },
              "description": "The time period to get statistics for: week, month, or year"
            }
          ],
          "responses": {
            "200": {
              "description": "Successful Response",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/EmotionStatisticsResponse"
                  }
                }
              }
            },
            "422": {
              "description": "Validation Error",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/HTTPValidationError"
                  }
                }
              }
            }
          }
        }
