<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_white"
        app:elevation="0dp">

                <include android:id="@+id/topBar" layout="@layout/view_top_bar" />

    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <org.osmdroid.views.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/filter_panel_background"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etDateFilter"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1.45"
                    android:background="@drawable/filter_input_background"
                    android:clickable="true"
                    android:drawableStart="@drawable/ic_calendar"
                    android:drawablePadding="8dp"
                    android:focusable="false"
                    android:gravity="center_vertical"
                    android:hint="Выбери дату"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFilter"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:minWidth="112dp"
                    android:background="@drawable/filter_button_background"
                    android:text="Фильтровать"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:backgroundTint="@null"
                    app:cornerRadius="10dp" />

            </LinearLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupEmotions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:checkedChip="@id/chipAllEmotions"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp"
                app:singleLine="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAllEmotions"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:checkable="true"
                    android:checked="true"
                    android:minWidth="128dp"
                    android:text="Все эмоции"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    app:chipCornerRadius="10dp"
                    app:chipMinHeight="48dp"
                    app:chipStrokeColor="@color/text_primary"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHappy"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:checkable="true"
                    android:minWidth="94dp"
                    android:text="Счастье"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    app:chipCornerRadius="10dp"
                    app:chipMinHeight="48dp"
                    app:chipStrokeColor="@color/text_primary"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipNeutral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="Нейтрально"
                    android:visibility="gone" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSad"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:checkable="true"
                    android:minWidth="82dp"
                    android:text="Грусть"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    app:chipCornerRadius="10dp"
                    app:chipMinHeight="48dp"
                    app:chipStrokeColor="@color/text_primary"
                    app:chipStrokeWidth="1dp" />

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardEmotionDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="80dp"
            android:maxHeight="200dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/background_white"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvEmotionLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:drawableStart="@drawable/ic_map"
                        android:drawablePadding="8dp"
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:maxLines="2"
                        android:text="Загородный проспект 21-23"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvEmotionRating"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Настроение: 7/10"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvEmotionDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Дата: 2023-10-12"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvEmotionComment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@color/background_light"
                        android:lineSpacingExtra="2dp"
                        android:padding="12dp"
                        android:text="Ждал девушку на первом свидании"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        app:cornerRadius="8dp" />

                </LinearLayout>

            </ScrollView>

        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/background_white"
        app:elevation="8dp"
        app:itemIconSize="32dp"
        app:itemIconTint="@null"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/bottom_navigation" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

